rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the single app document is accessible.
    // Anonymous auth (request.auth != null) is sufficient — blocks unauthenticated REST calls.
    match /app_data/main {
      allow read: if request.auth != null;
      allow write: if request.auth != null && validAppData(request.resource.data);
    }

    // Deny every other path in the database.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function validAppData(data) {
  return data.keys().hasAll([
           'masterTeachers',
           'fullTimetable',
           'reliefTasksByDate',
           'termStartDates',
           'messageTemplate'
         ])
    && data.masterTeachers is list
    && data.messageTemplate is string
    && data.termStartDates is map
    && data.termStartDates.keys().hasAll(['term1', 'term2', 'term3', 'term4']);
}
